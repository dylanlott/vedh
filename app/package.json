{
  "name": "vedh-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:smoke": "node ./scripts/smoke-create-join.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "@vue/apollo-composable": "^4.0.0-beta.12",
    "graphql": "^16.9.0",
    "graphql-ws": "^5.14.3",
    "pinia": "^2.1.7",
    "uplot": "^1.6.30",
    "vue": "^3.5.4",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.5.4",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^22.1.0",
    "sass": "^1.77.8",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^1.1.9",
    "vue-tsc": "^2.1.8"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true
  }
}
